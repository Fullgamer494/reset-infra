  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "peerDependencies": {
    "@prisma/client": "^7.4.0",
    "zod": "^3.22.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "prisma": "^7.4.1",
    "typescript": "^5.9.3",
    "zod-prisma-types": "^3.3.11"
  }
}